@page "/roles"

@using BluQube.Commands
@using BluQube.Constants
@using BluQube.Queries
@using IBMG.SCS.Portal.Web.Client.Components.JobRole
@using IBMG.SCS.Portal.Web.Client.Dtos
@using IBMG.SCS.Portal.Web.Client.Infrastructure.Commands.DeleteJobRoleCommand
@using IBMG.SCS.Portal.Web.Client.Infrastructure.Queries
@inject DialogService DialogService
@inject IQuerier Querier

<div class="operative-management">
    <div class="trade-card-management px-3 py-2">
        <h3>Operative Roles</h3>
        <RadzenRow AlignItems="AlignItems.Center" Gap="10px">
            <RadzenColumn Size="12" SizeMd="6" SizeLg="4" class="mt-2">
                <div class="search-wrapper form-group">
                    <input type="text"
                           class="form-control search-input"
                           placeholder="SEARCH ROLE"
                           @bind:event="oninput"
                           @bind="searchText" />
                    <svg class="search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
                        <path d="M14.2939 12.5786H13.3905L13.0703 12.2699C14.191 10.9663 14.8656 9.27387 14.8656 7.43282C14.8656 3.32762 11.538 0 7.43282 0C3.32762 0 0 3.32762 0 7.43282C0 11.538 3.32762 14.8656 7.43282 14.8656C9.27387 14.8656 10.9663 14.191 12.2699 13.0703L12.5786 13.3905V14.2939L18.2962 20L20 18.2962L14.2939 12.5786ZM7.43282 12.5786C4.58548 12.5786 2.28702 10.2802 2.28702 7.43282C2.28702 4.58548 4.58548 2.28702 7.43282 2.28702C10.2802 2.28702 12.5786 4.58548 12.5786 7.43282C12.5786 10.2802 10.2802 12.5786 7.43282 12.5786Z"
                              fill="#4F6A7B" />
                    </svg>
                </div>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMd="6" SizeLg="8"
                          class="icon-btn-group d-flex justify-content-md-end gap-2 mt-2 mt-md-0">

                <RadzenButton Icon="add"
                              Click="OpenAdd"
                              ButtonStyle="ButtonStyle.Primary" />

                <RadzenButton Icon="filter_alt"
                              ButtonStyle="ButtonStyle.Primary" />

                <RadzenButton Icon="filter_alt_off"
                              ButtonStyle="ButtonStyle.Danger" />

            </RadzenColumn>
            <RadzenRow>
                <div class="scrollable-grid" id="tradecard-export">
                    <RadzenDataGrid TItem="JobRoleDto"
                                    Data="@FilteredRoles"
                                    Class="mt-3 trade-card-grid"
                                    AllowSorting="true"
                                    AllowFiltering="false"
                                    AllowPaging="false"
                                    AllowAlternatingRows="true"
                                    GridLines="DataGridGridLines.None"
                                    ColumnWidth="120px">

                        <Columns>
                            <RadzenDataGridColumn TItem="JobRoleDto"
                                                  Property="Name"
                                                  Title="Role"
                                                  Sortable="true" />

                            <RadzenDataGridColumn TItem="JobRoleDto"
                                                  Property="UserCount"
                                                  Title="User Count"
                                                  Sortable="true" />

                            <RadzenDataGridColumn TItem="JobRoleDto"
                                                  Filterable="false"
                                                  TextAlign="TextAlign.Right" 
                                                  Sortable="false">

                                <Template Context="row">
                                    <RadzenButton Icon="edit_square"
                                                  Size="ButtonSize.Small"
                                                  IconColor="#4F6A7B"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  Click="() => OpenEdit(row)" />

                                    @if (row.UserCount == 0)
                                    {
                                        <RadzenButton Icon="delete"
                                                      Size="ButtonSize.Small"
                                                      Style="margin-left: 6px; color:#4F6A7B"
                                                      ButtonStyle="ButtonStyle.Danger"
                                                      Click="() => DeleteRole(row.Id)"/>
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>

                    </RadzenDataGrid>
                </div>
            </RadzenRow>
        </RadzenRow>
    </div>
</div>