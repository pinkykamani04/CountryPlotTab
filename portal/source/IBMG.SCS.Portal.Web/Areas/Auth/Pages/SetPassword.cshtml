@page
@model SetPassword
@{
ViewData["Title"] = "Set Your Password";
ViewData["PageFunc"] = "password-reset";
}

<section id="auth-container" class="d-flex justify-content-end">
    <div class="col-12 col-lg-6 d-flex justify-content-center align-items-center min-vh-100 bg-white px-5">
        <div class="w-100 d-flex justify-content-center align-items-center flex-column">
            <div class="auth-logo">
                <img src="~/assets/assets/auth-logo.png" alt="IBMG Supply Chain Services" />
            </div>
            <h3 class="p-2 rounded-title mt-4 mb-0">New Password</h3>
            @if (Model.IsInError)
            {
            <div>Sorry, something went wrong. Please try again.</div>
            }
            <form class="form-horizontal" asp-antiforgery="true" method="post" >
                <small>Enter the new password, your password will change and you will be logged in.</small>
                <div class="form-group mt-4 mb-3">
                    <label asp-for="PageModel!.CurrentPassword" class="form-label"></label>
                    <input class="form-control" type="password" asp-for="PageModel!.CurrentPassword" />
                    <span class="text-danger small" asp-validation-for="PageModel!.CurrentPassword"></span>
                </div>
                <div class="form-group mt-4 mb-3">
                    <label asp-for="PageModel!.Password" class="form-label"></label>
                    <input class="form-control" type="password" asp-for="PageModel!.Password" />
                    <span class="text-danger small" asp-validation-for="PageModel!.Password"></span>
                </div>
                <div class="form-group">
                    <label asp-for="PageModel!.PasswordConfirmation" class="form-label"></label>
                    <input class="form-control" type="password" asp-for="PageModel!.PasswordConfirmation" />
                    <span class="text-danger small" asp-validation-for="PageModel!.PasswordConfirmation"></span>
                </div>
                <div class="d-grid mt-4 mb-4">
                    <button class="btn btn-primary btn-lg" type="submit" data-processable>Change Password</button>
                </div>
            </form>
            
        </div>
    </div>
</section>