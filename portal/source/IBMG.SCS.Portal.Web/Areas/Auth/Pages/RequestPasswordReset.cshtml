@page "/auth/request-password-reset"
@using PearDrop.Authentication.Constants
@using PearDrop.Authentication.RazorPages.Constants
@model RequestPasswordReset
@{
    ViewData["Title"] = "Forgotten Password";
    ViewData["PageFunc"] = "request-password-reset";
}

<div id="auth-container">
    <!-- Left Side - Image Section -->
    <div class="auth-image-section">
        <!-- Background image will be applied via CSS -->
    </div>

    <!-- Right Side - Form Section -->
    <div class="auth-form-section">
        <div class="auth-form-container">
            <form asp-antiforgery="true" method="post">
                <!-- Logo -->
                <div class="auth-logo">
                    <img src="~/assets/assets/auth-logo.png" alt="IBMG Supply Chain Services" />
                </div>

                <h1 class="auth-title">Forgot Your Password?</h1>
                
                @if (Model.Completed)
                {
                    <div class="alert alert-success" style="background-color: #d4edda; border: 1px solid #c3e6cb; color: #155724; padding: 1rem; border-radius: 4px; margin-bottom: 1.5rem;">
                        <i class="fas fa-check-circle"></i> Please check your emails for the reset details.
                    </div>
                    <a href="@Url.Page(AuthPageLocations.AuthSignIn, new { area = "auth" })" class="btn-primary" style="display: inline-block; text-align: center; text-decoration: none;">
                        Return to Login
                    </a>
                }
                else
                {
                    <p style="color: var(--text-muted); margin-bottom: 2rem;">Please confirm your username below and we will send you a reset link.</p>
                    
                    <div class="form-group">
                        <label asp-for="PageModel!.Username" class="form-label">Username / E-mail</label>
                        <div class="input-group">
                            <i class="input-icon fas fa-envelope"></i>
                            <input class="form-control" type="text" asp-for="PageModel!.Username" placeholder="Enter your email" />
                        </div>
                        <span class="text-danger" asp-validation-for="PageModel!.Username"></span>
                    </div>
                    
                    <div class="form-group">
                        <button class="btn-primary" type="submit" data-processable>Send Reset Link</button>
                    </div>
                    
                    <div style="text-align: center; margin-top: 1.5rem;">
                        <a href="@Url.Page(AuthPageLocations.AuthSignIn, new { area = "auth" })" class="auth-link">
                            <i class="fas fa-arrow-left"></i> Return to login
                        </a>
                    </div>
                }
            </form>
        </div>
    </div>
</div>