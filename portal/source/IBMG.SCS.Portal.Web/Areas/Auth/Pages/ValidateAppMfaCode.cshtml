@page "/auth/multi-factor-app"
@model ValidateAppMfaCode
@{
    ViewData["Title"] = "Validate Your Login";
    ViewData["PageFunc"] = "app-factor";
}

<section id="auth-container" class="d-flex justify-content-end">
    <div class="col-12 col-lg-6 d-flex justify-content-center align-items-center min-vh-100 bg-white px-5">
        <div class=" w-100">
            <form class="form-horizontal" asp-antiforgery="true" method="post">
                <div class="auth-logo">
                    <img src="~/assets/assets/auth-logo.png" alt="IBMG Supply Chain Services" />
                </div>
                <h4 class="rounded-title mt-4 mb-0">Use Authenticator App</h4>
                <small>Open your authentication app and enter the code.</small>
                @if (Model.InError)
                {
                    <p class="text-danger">There was a problem validating your code. Please try again. If it continues please try one of the other methods</p>
                }
                <div class="form-group mt-4 mb-3">
                    <div class="col-xs-12">
                        <label asp-for="PageModel!.Code" class="form-label"></label>
                        <input class="form-control" type="text" asp-for="PageModel!.Code" autocomplete="off">
                        <span class="text-danger small" asp-validation-for="PageModel!.Code"></span>
                    </div>
                </div>
                
                @if (Model.DeviceRemembranceExpirationInDays > -1)
                {
                    <div class="form-check mt-4 mb-3">
                        <input class="form-check-input" type="checkbox" asp-for="PageModel!.RememberDevice">
                        <label class="form-check-label" asp-for="PageModel!.RememberDevice">
                            Do not ask for a code on this device again for the next @Model.DeviceRemembranceExpirationInDays day(s)
                        </label>
                    </div>
                }

                <div class="d-grid mt-4 mb-4">
                    <button class="btn btn-primary btn-lg" type="submit" data-processable>Authenticate</button>
                </div>
            </form>

            <hr />
            <p>Or select a different method</p>

            <form class="feeds m-0 p-0 mt-3 pt-2" method="post">
                @await Html.PartialAsync("_MfaOptions", Model.MfaProviders)
            </form>
        </div>
    </div>
</section>