<RadzenColumn class="@CssClass" Size="@Size" SizeSM="@SizeSM" SizeMD="@SizeMD" SizeLG="@SizeLG" SizeXL="@SizeXL" SizeXS="@SizeXS" SizeXX="@SizeXX">
    <RadzenCard Class="h-100 shadow-sm p-3" Style="border-radius: 12px;">
        <RadzenRow AlignItems="AlignItems.Center">
            <RadzenColumn Size="4">
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Center" AlignItems="AlignItems.Center" class="border-radius-50"
                             Style='@($"width:55px;height:55px;background-color:{IconBackground};")'>
                    <RadzenIcon Icon="@Icon" IconColor="@IconColor" class="fs-26" />
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn Size="8">
                <RadzenStack Gap="6">
                    <RadzenText Text="@CardText" TextStyle="TextStyle.H6" class="dark-blue-color" />
                    <RadzenText Text="@CardNumber" TextStyle="TextStyle.H5" class="fw-600" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    </RadzenCard>
</RadzenColumn>
