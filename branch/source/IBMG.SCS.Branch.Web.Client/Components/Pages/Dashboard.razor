@page "/test-design"

<RadzenStack Gap="30px" Style="padding:30px;" class="dashboard w-100">
    <RadzenText Text="Design System" TextStyle="TextStyle.H2" class="brand-heading" />
    <RadzenCard>
        <RadzenText Text="Typography" TextStyle="TextStyle.H4" class="brand-heading" />

        <RadzenStack Gap="15px" Style="margin-top:20px;">
            <RadzenText Text="Heading 1 - Page Title" TextStyle="TextStyle.H1" class="brand-heading" />
            <RadzenText Text="Heading 2 - Section Title" TextStyle="TextStyle.H2" class="brand-heading" />
            <RadzenText Text="Heading 3 - Card Title" TextStyle="TextStyle.H3" class="brand-heading" />
            <RadzenText Text="Heading 4 - Subsection" TextStyle="TextStyle.H4" class="brand-heading" />
            <RadzenText Text="Paragraph text example. This is body copy used across the application." />
            <RadzenText Text="Label Text" class="brand-label" />
            <RadzenText Text="Muted Text Example" class="text-muted" />
            <RadzenText Text="Bold Text Example" class="fw-bold" />
            <RadzenText Text="Italic Text Example" Style="font-style:italic;" />
        </RadzenStack>
    </RadzenCard>
    <RadzenCard>
        <RadzenText Text="Colours" TextStyle="TextStyle.H4" class="brand-heading" />

        <RadzenRow class="mt-3">
            <RadzenColumn Size="12" SizeMD="3">
                <RadzenStack class="color-box brand-primary"></RadzenStack>
                <RadzenText Text="Primary" />
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="3">
                <RadzenStack class="color-box brand-success"></RadzenStack>
                <RadzenText Text="Success" />
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="3">
                <RadzenStack class="color-box brand-warning"></RadzenStack>
                <RadzenText Text="Warning" />
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="3">
                <RadzenStack class="color-box brand-danger"></RadzenStack>
                <RadzenText Text="Danger" />
            </RadzenColumn>
        </RadzenRow>
    </RadzenCard>
    <RadzenRow class="mt-3">
        <RadzenColumn Size="12" SizeMD="3">
            <RadzenButton Size="ButtonSize.Medium"
                          Text="Primary"
                          ButtonStyle="ButtonStyle.Primary"
                          Style="width:100%;" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3">
            <RadzenButton Size="ButtonSize.Medium"
                          Text="Secondary"
                          ButtonStyle="ButtonStyle.Secondary"
                          Style="width:100%;" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3">
            <RadzenButton Size="ButtonSize.Medium"
                          Text="Filter Button"
                          ButtonStyle="ButtonStyle.Danger"
                          Style="width:100%;" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3">
            <RadzenButton Size="ButtonSize.Medium"
                          Text="Success Button"
                          ButtonStyle="ButtonStyle.Success"
                          Style="width:100%;" />
        </RadzenColumn>
    </RadzenRow>
    <RadzenStack>
        <RadzenText Text="Stock & Availability" Class="rz-h5 rz-mb-3" />
        <RadzenRow>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenCard>
                    <h3 class="rz-mt-0">Overall Core Stock Availability</h3>
                    <RadzenArcGauge Style="width: 100%; height: 250px;">
                        <RadzenArcGaugeScale Step="20" Min="0" Max="260" MinorStep="2" Radius="1.5" TickPosition=@tickPosition Y="0.9" Margin="0">
                            <RadzenArcGaugeScaleValue Value=@value ShowValue=@showValue>
                                <Template Context="pointer">
                                    <RadzenStack AlignItems="AlignItems.Center" Gap="0" Style="margin-top: -50%;">
                                        <RadzenText TextStyle="TextStyle.H5" class="rz-m-0"><strong>@pointer.Value</strong></RadzenText>
                                        <RadzenText TextStyle="TextStyle.Caption">km/h</RadzenText>
                                    </RadzenStack>
                                </Template>
                            </RadzenArcGaugeScaleValue>
                        </RadzenArcGaugeScale>
                    </RadzenArcGauge>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenCard>
                    <RadzenText Text="Branches Meeting Target" Class="rz-text-primary rz-font-weight-semibold" />
                    <RadzenChart>
                        <RadzenPieSeries Data="@revenue" Title="Revenue" CategoryProperty="Quarter" ValueProperty="Revenue">
                            <RadzenSeriesDataLabels />
                        </RadzenPieSeries>
                    </RadzenChart>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenCard>
                    <h3 class="rz-mt-0">Average Daily Stock Gap</h3>

                    <RadzenRadialGauge Min="0" Max="10" Value="3.5" Style="height:200px;">
                        <RadzenRadialGaugeScale StartAngle="-140" EndAngle="140">
                            <RadzenRadialGaugeScaleRange From="0" To="4" Fill="#82d97a" />
                            <RadzenRadialGaugeScaleRange From="4" To="7" Fill="#f6e68c" />
                            <RadzenRadialGaugeScaleRange From="7" To="10" Fill="#e57373" />
                        </RadzenRadialGaugeScale>
                    </RadzenRadialGauge>

                    <div class="rz-text-center rz-mt-2">
                        <h1 class="rz-m-0">3.5%</h1>
                        <span>Daily Stock Gap</span>
                    </div>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>
    </RadzenStack>
    <RadzenCard>
        <RadzenText Text="Cards" TextStyle="TextStyle.H4" class="brand-heading" />

        <RadzenRow class="mt-3">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenCard>
                    <RadzenText Text="Card Title" TextStyle="TextStyle.H4" class="brand-heading" />
                    <RadzenText Text="This is a standard card layout example." />
                </RadzenCard>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenCard Style="background:#F2F4F7;">
                    <RadzenText Text="Muted Card" class="brand-heading" />
                    <RadzenText Text="Used for contextual blocks." />
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>
    </RadzenCard>
    <RadzenCard Style="padding:25px; max-width:750px; margin:auto;">

        <RadzenTemplateForm TItem="ValidationFormModel"
                            Data="@Model"
                            Submit="@OnSubmit">

            <RadzenStack Gap="20px">

                <RadzenStack>
                    <RadzenText Text="Customer*" class="brand-label" />
                    <RadzenDropDown Name="customer"
                                    @bind-Value="Model.Customer"
                                    Data="@Customers"
                                    Style="width:100%;"
                                    Placeholder="Select customer" />
                    <RadzenRequiredValidator Component="customer"
                                             Text="Customer is required" />
                </RadzenStack>
                <RadzenRow>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenStack>
                            <RadzenText Text="Job number*" class="brand-label" />
                            <RadzenTextBox Name="job"
                                           @bind-Value="Model.JobNumber"
                                           Style="width:100%;"
                                           class="input-field" />
                            <RadzenRequiredValidator Component="job"
                                                     Text="Job number is required" />
                        </RadzenStack>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenStack>
                            <RadzenText Text="Trade card number*" class="brand-label" />
                            <RadzenTextBox Name="card"
                                           @bind-Value="Model.TradeCardNumber"
                                           Style="width:100%;"
                                           class="input-field" />
                            <RadzenRequiredValidator Component="card"
                                                     Text="Trade card number is required" />
                        </RadzenStack>
                    </RadzenColumn>

                </RadzenRow>
                <RadzenStack>
                    <RadzenText Text="Operative ID*" class="brand-label" />
                    <RadzenTextBox Name="opid"
                                   @bind-Value="Model.OperativeId"
                                   Style="width:100%;"
                                   class="input-field" />
                    <RadzenRequiredValidator Component="opid"
                                             Text="Operative ID is required" />
                </RadzenStack>
                <RadzenRow class="mt-2">

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenButton Text="VALIDATE"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Style="width:100%; padding:12px; font-weight:600;"
                                      Type="ButtonType.Submit" />
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenButton Text="ADD ORDER" Click="AddOrder"
                                      Disabled="@(!IsValidated)"
                                      Style="width:100%; padding:12px; font-weight:600; background:#d9d9d9; color:#7b7b7b;" />
                    </RadzenColumn>

                </RadzenRow>

            </RadzenStack>
        </RadzenTemplateForm>
    </RadzenCard>
    <RadzenCard class="mb-5 shadow-sm p-3">
        <RadzenDataGrid Data="@demo" TItem="DemoRow">
            <Columns>
                <RadzenDataGridColumn TItem="DemoRow" Property="Id" Title="ID" Width="80px" />
                <RadzenDataGridColumn TItem="DemoRow" Property="Name" Title="Name" />
                <RadzenDataGridColumn TItem="DemoRow" Property="Status" Title="Status">
                    <Template Context="item">
                        <RadzenBadge Text="@item.Status"
                                     Style="@(item.Status=="Active"? "background:#4caf50;color:white": "background:#e0e0e0;color:#555")" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="DemoRow" Title="Actions" Width="120px">
                    <Template Context="item">
                        <RadzenButton Icon="edit" Size="ButtonSize.Small"
                                      ButtonStyle="ButtonStyle.Light"
                                      class="me-2" />
                        <RadzenButton Icon="delete" Size="ButtonSize.Small"
                                      ButtonStyle="ButtonStyle.Danger" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>
</RadzenStack>

